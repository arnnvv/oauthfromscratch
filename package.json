{
  "name": "oauthlrn",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "d": "next dev --turbopack",
    "b": "next build",
    "st": "next start",
    "f": "pnpm biome format --write .",
    "l": "pnpm biome lint --write .",
    "dg": "drizzle-kit generate --config=drizzle.config.ts",
    "dm": "drizzle-kit migrate --config=drizzle.config.ts",
    "dp": "drizzle-kit pull --config=drizzle.config.ts",
    "du": "drizzle-kit up --config=drizzle.config.ts",
    "dc": "drizzle-kit check --config=drizzle.config.ts",
    "ds": "drizzle-kit studio --config=drizzle.config.ts"
  },
  "dependencies": {
    "next": "^15.1.6",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "drizzle-orm": "^0.39.1",
    "@neondatabase/serverless": "^0.10.4"
  },
  "devDependencies": {
    "@biomejs/biome": "1.9.4",
    "@types/node": "^22.12.0",
    "@types/react": "^19.0.8",
    "@types/react-dom": "^19.0.3",
    "drizzle-kit": "^0.30.4",
    "typescript": "^5"
  },
  "pnpm": {
    "ignoredBuiltDependencies": ["@biomejs/biome", "esbuild", "sharp"],
    "onlyBuiltDependencies": ["@biomejs/biome", "esbuild", "sharp"]
  }
}
